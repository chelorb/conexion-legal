# ============================================================
# backend/.env.example — Variables de entorno del Backend
# Copiar este archivo como .env y completar los valores reales
# NUNCA subir el .env real a Git
# ============================================================

# ─── Servidor ───────────────────────────────────────────────
NODE_ENV=development          # development | production
PORT=3001
FRONTEND_URL=http://localhost:5173   # En prod: https://conexion-legal-xi.vercel.app

# ─── Base de datos (Neon PostgreSQL) ────────────────────────
DATABASE_URL=postgresql://usuario:password@host/database?sslmode=require

# ─── Autenticación JWT ──────────────────────────────────────
JWT_SECRET=cambiar_por_secreto_seguro_de_al_menos_32_caracteres
# 8h cubre una jornada laboral completa.
# El cierre por inactividad (30 min) en el frontend es la primera línea de defensa.
JWT_EXPIRES_IN=8h

# ─── Email (SendGrid HTTP API) ───────────────────────────────
# Render bloquea SMTP en plan gratuito — usar SendGrid API
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@iustixium.com.ar
EMAIL_FROM_NAME=IUSTIXIUM

# ─── Cloudinary (almacenamiento de documentos y avatares) ───
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ─── hCaptcha (protección contra bots en registro) ──────────
HCAPTCHA_SECRET_KEY=ES_xxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── MercadoPago (pagos — pendiente de activar) ─────────────
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
