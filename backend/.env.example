# ============================================================
# .env.example — Variables de entorno del Backend
# Copiar este archivo como .env y completar los valores reales
# NUNCA subir el .env real a Git
# ============================================================

# ─── Servidor ───────────────────────────────────────────────
NODE_ENV=development          # development | production
PORT=3001                     # Puerto donde corre el servidor

# ─── Base de datos ──────────────────────────────────────────
DATABASE_URL=postgresql://usuario:password@localhost:5432/conexion_legal

# ─── Autenticación JWT ──────────────────────────────────────
JWT_SECRET=reemplazar_con_string_largo_y_aleatorio_minimo_32_chars
JWT_EXPIRES_IN=7d             # Tiempo de expiración del token

# ─── MercadoPago (pagos de suscripciones) ───────────────────
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxx
MP_PUBLIC_KEY=APP_USR-xxxxxxxxxxxxxxxxxxxx
MP_WEBHOOK_SECRET=xxxxxxxxxx  # Para validar webhooks

# ─── Email (notificaciones) ─────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@conexionlegal.com.ar
SMTP_PASS=password_de_aplicacion_gmail

# ─── Frontend ───────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173   # En prod: https://conexionlegal.com.ar

# ─── Archivos (subida de fotos de perfil, documentos) ───────
UPLOAD_MAX_SIZE_MB=5
UPLOAD_PATH=./uploads
