# ============================================================
# Variables de entorno del backend — Conexión Legal
# Copiar a .env y completar con valores reales
# ============================================================

# Entorno
NODE_ENV=development         # development | production

# Servidor
PORT=3001
FRONTEND_URL=http://localhost:5173   # En prod: https://tu-app.vercel.app

# Base de datos PostgreSQL (Neon)
DATABASE_URL=postgresql://usuario:password@host/database?sslmode=require

# Autenticación JWT
JWT_SECRET=cambiar_por_secreto_seguro_de_al_menos_32_caracteres
JWT_EXPIRES_IN=7d

# Email SMTP (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tucorreo@gmail.com
SMTP_PASS=app_password_de_gmail   # No la contraseña normal, sino App Password

# MercadoPago (pendiente de configurar)
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
